# Application runtime
APP_NAME=Agentic Job Hunter
ENVIRONMENT=development
LOG_LEVEL=INFO
PORT=8000

# Secrets
AGENT_API_KEY=replace-with-a-shared-api-key
OPENAI_API_KEY=replace-with-openai-api-key
GEMINI_API_KEY=replace-with-gemini-api-key

# Redis
REDIS_URL=redis://redis:6379/0

# Models and provider behavior
OPENAI_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini-2.5-flash
MODEL_TEMPERATURE=0.2
OPENAI_TIMEOUT_SECONDS=30
GEMINI_TIMEOUT_SECONDS=30
OPENAI_MAX_OUTPUT_TOKENS=800
GEMINI_MAX_OUTPUT_TOKENS=800

# Security and cost controls
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60
MONTHLY_BUDGET_USD=10.00
REQUEST_RESERVE_USD=0.25

# Session and shutdown behavior
SESSION_TTL_SECONDS=604800
HISTORY_MAX_MESSAGES=20
GRACEFUL_SHUTDOWN_TIMEOUT_SECONDS=20

# Per-provider pricing for actual token cost settlement
OPENAI_INPUT_PRICE_PER_1K_USD=0.00015
OPENAI_OUTPUT_PRICE_PER_1K_USD=0.00060
GEMINI_INPUT_PRICE_PER_1K_USD=0.00010
GEMINI_OUTPUT_PRICE_PER_1K_USD=0.00040
